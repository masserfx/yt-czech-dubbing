{
  "manifest_version": 3,
  "name": "YouTube Dubbing — CS SK PL HU",
  "version": "2.1.0",
  "description": "YouTube video dubbing - automatic translation and voice output in Czech, Slovak, Polish, Hungarian",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "sidePanel",
    "offscreen",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://api.mymemory.translated.net/*",
    "https://libretranslate.de/*",
    "https://translate.argosopentech.com/*",
    "https://translate.terraprint.co/*",
    "https://translate.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://api-free.deepl.com/*",
    "https://api.deepl.com/*",
    "https://*.tts.speech.microsoft.com/*",
    "https://*.api.cognitive.microsoft.com/*",
    "https://generativelanguage.googleapis.com/*",
    "wss://speech.platform.bing.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": [
        "src/page-script.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": [
        "src/caption-extractor.js",
        "src/language-config.js",
        "src/service-mode.js",
        "src/translator.js",
        "src/tts-engine.js",
        "src/dubbing-cache.js",
        "src/dubbing-controller.js",
        "src/content.js"
      ],
      "css": [
        "src/overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "edge_tts_headers",
        "enabled": true,
        "path": "rules/edge-tts-headers.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
